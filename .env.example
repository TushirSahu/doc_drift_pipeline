# ── Vector store ────────────────────────────────────────────────────────────
# Pick ONE of the three modes:
#
# 1) Embedded on-disk (DEFAULT, no server/cloud needed) — leave QDRANT_URL empty.
#    Optionally set a custom path:
# QDRANT_PATH=./qdrant_storage
#
# 2) In-memory (ephemeral, lost on exit — handy for quick tests):
# QDRANT_PATH=:memory:
#
# 3) Remote / Qdrant Cloud — set the URL (this takes precedence over QDRANT_PATH):
# QDRANT_URL=https://your-cluster.cloud.qdrant.io
# QDRANT_API_KEY=your-api-key-here

# Leave QDRANT_URL empty to use embedded mode.
QDRANT_URL=
QDRANT_API_KEY=
OPENAI_API_KEY=
# HuggingFace Inference Router token — used by the HF entries in models.registry
# (the multi-LLM benchmark). Referenced via api_key_env: HF_TOKEN in config.yaml.
# Create one at https://huggingface.co/settings/tokens
HF_TOKEN=
# Optional: collection name override
# QDRANT_COLLECTION=
QDRANT_COLLECTION=docdrift_bge

# API auth — if set, all endpoints except /health require this key via X-API-Key.
# Leave unset for local/dev (auth disabled).
DOCDRIFT_API_KEY=
DOCDRIFT_CORS_ORIGINS="https://doc-drift-pipeline.vercel.app/"

# ── Model provider ──────────────────────────────────────────────────────────
# Default is Ollama (local). For cloud hosting set models.provider: openai in
# config.yaml and provide an OpenAI-compatible endpoint below.
# LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.groq.com/openai/v1   # Groq; or HF router / OpenAI / vLLM
# LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct        # model id for the chosen provider
# EMBED_PROVIDER=sentence_transformers              # embeddings run locally on CPU
# EMBED_MODEL=BAAI/bge-small-en-v1.5                # (EMBED_MODEL overrides models.embed)
#
# Env vars override config.yaml, so the same code runs on Ollama (CI/local) or any
# provider in deployment. Examples:
#   Groq:  LLM_PROVIDER=openai OPENAI_BASE_URL=https://api.groq.com/openai/v1 LLM_MODEL=llama-3.1-8b-instant
#   HF:    LLM_PROVIDER=openai OPENAI_BASE_URL=https://router.huggingface.co/v1 LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
#   vLLM:  LLM_PROVIDER=openai OPENAI_BASE_URL=http://vllm-host:8000/v1 LLM_MODEL=<served-id>

# Browser/demo origin allowlist for the deployed API (default: *)
# DOCDRIFT_CORS_ORIGINS=https://your-frontend.vercel.app

# Optional: store feedback + regression cases in Postgres instead of JSONL files.
# DATABASE_URL=postgresql://user:pass@host:5432/docdrift
