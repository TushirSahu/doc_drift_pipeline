# ── Vector store ────────────────────────────────────────────────────────────
# Pick ONE of the three modes:
#
# 1) Embedded on-disk (DEFAULT, no server/cloud needed) — leave QDRANT_URL empty.
#    Optionally set a custom path:
# QDRANT_PATH=./qdrant_storage
#
# 2) In-memory (ephemeral, lost on exit — handy for quick tests):
# QDRANT_PATH=:memory:
#
# 3) Remote / Qdrant Cloud — set the URL (this takes precedence over QDRANT_PATH):
# QDRANT_URL=https://your-cluster.cloud.qdrant.io
# QDRANT_API_KEY=your-api-key-here

# Leave QDRANT_URL empty to use embedded mode.
QDRANT_URL=
QDRANT_API_KEY=

# Optional: collection name override
QDRANT_COLLECTION=default_collection

# API auth — if set, all endpoints except /health require this key via X-API-Key.
# Leave unset for local/dev (auth disabled).
DOCDRIFT_API_KEY=
